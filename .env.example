# ──────────────────────────────────────────────────────────────
# ARCHIVO: .env.example
# PROPÓSITO: Muestra qué variables de entorno necesita la app.
# INSTRUCCIÓN: Copia este archivo como ".env" y llena los valores.
# ¡NUNCA subas el archivo .env a GitHub!
# ──────────────────────────────────────────────────────────────

# ─── Django Core ─────────────────────────────────────────────
# Clave secreta única del proyecto (genera una en: https://djecrety.ir/)
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-muy-larga

# En desarrollo: True | En producción: False
DJANGO_DEBUG=False

# Dominio donde corre la app (ej: mi-app.railway.app,localhost)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos ────────────────────────────────────────────
# Railway provee esta variable automáticamente al agregar PostgreSQL
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/nombre_db

# ─── Email (notificaciones) ───────────────────────────────────
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=soporte@unidossis.com.co
EMAIL_HOST_PASSWORD=tu_contraseña_de_correo
DEFAULT_FROM_EMAIL=Unidossis PQRS <soporte@unidossis.com.co>

# ─── IA / Google Gemini ───────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_de_gemini_aqui

# ─── WhatsApp Business API (futuro) ──────────────────────────
# WHATSAPP_API_TOKEN=tu_token_de_meta
# WHATSAPP_PHONE_ID=tu_phone_id
